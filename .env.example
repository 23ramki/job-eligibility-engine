# ── LLM API Keys (at least one required) ──────────────────────────────────────
# Groq (free tier): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (free tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Job Sourcing ───────────────────────────────────────────────────────────────
# TheirStack API: https://theirstack.com
THEIRSTACK_API_KEY=your_theirstack_api_key_here

# ── Notifications (optional) ──────────────────────────────────────────────────
# Discord webhook for new-job alerts (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# ── Model overrides (optional) ────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash-lite
# GROQ_MODEL=llama-3.1-8b-instant

# ── Daily quota limits (optional — defaults shown) ────────────────────────────
# GROQ_DAILY_TOKEN_LIMIT=28800
# GROQ_DAILY_REQ_LIMIT=500
# GEMINI_DAILY_TOKEN_LIMIT=250000
# GEMINI_DAILY_REQ_LIMIT=1500
